{
  "name": "rss-accordion",
  "version": "0.7.0",
  "description": "A custom Lovelace card for Home Assistant to display RSS feed items in an accordion style.",
  "homepage": "https://github.com/timmaurice/lovelace-rss-accordion#readme",
  "bugs": {
    "url": "https://github.com/timmaurice/lovelace-rss-accordion/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/timmaurice/lovelace-rss-accordion.git"
  },
  "license": "MIT",
  "author": "Tim Maurice Bayer",
  "type": "module",
  "main": "dist/rss-accordion.js",
  "scripts": {
    "build": "rollup -c",
    "check-format": "prettier --check .",
    "format": "prettier . --write",
    "lint": "eslint .",
    "test": "NODE_ENV=production vitest run",
    "watch": "rollup -c -w"
  },
  "devDependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-wc": "^3.1.0",
    "jsdom": "^29.0.1",
    "lit": "^3.3.2",
    "prettier": "^3.8.1",
    "rollup": "^4.60.1",
    "rollup-plugin-lit-css": "^6.0.1",
    "sass": "^1.98.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
